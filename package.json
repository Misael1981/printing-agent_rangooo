{
  "name": "printing-agent_rangooo",
  "version": "2.0.2",
  "description": "Agente de impressão local do Rangooo",
  "author": "Misael Borges",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder",
    "build:win": "electron-builder --win"
  },
  "build": {
    "appId": "com.rangooo.agente",
    "productName": "Agente de Impressao Rangooo",
    "directories": {
      "output": "dist",
      "buildResources": "build"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "Misael1981",
        "repo": "printing-agent_rangooo"
      }
    ],
    "extraResources": [
      ".env"
    ],
    "win": {
      "target": "nsis",
      "icon": "src/public/assets/icon.png"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false
    },
    "npmRebuild": false
  },
  "dependencies": {
    "auto-launch": "^5.0.6",
    "dotenv": "^17.2.3",
    "electron-store": "^8.1.0",
    "electron-updater": "^6.6.2",
    "node-thermal-printer": "^4.5.0",
    "serialport": "^13.0.0",
    "winston": "^3.19.0",
    "ws": "^8.18.3"
  },
  "devDependencies": {
    "electron": "^33.2.1",
    "electron-builder": "^26.0.12"
  },
  "license": "ISC"
}
